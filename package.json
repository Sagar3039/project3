{
  "name": "bob-ai-assistant",
  "version": "1.0.0",
  "description": "Bob — Your personal AI assistant powered by local Ollama models. Built with Electron + React. Supports voice input and voice output.",
  "main": "electron/main.js",
  "author": "Sagar",
  "license": "MIT",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:vite": "vite build",
    "build": "npm run build:vite && electron-builder",
    "dist:win": "npm run build:vite && electron-builder --win"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "edge-tts": "^1.0.1",
    "node-edge-tts": "^1.2.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.sagar.bob-ai-assistant",
    "productName": "Bob AI Assistant",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
